{
  "name": "sbom-generator-desktop",
  "version": "1.2.2",
  "private": true,
  "type": "module",
  "description": "Double-click desktop app that wraps the BomLens web UI (runs the scanner in Docker).",
  "main": "main.mjs",
  "scripts": {
    "test": "node --test test/*.test.mjs",
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis",
    "dist:mac": "electron-builder --mac dmg",
    "dist:linux": "electron-builder --linux AppImage"
  },
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1"
  }
}
