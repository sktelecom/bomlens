{
  "name": "sbom-tools-web",
  "version": "1.0.0",
  "private": true,
  "description": "sbom-tools local web UI — React 18 + Vite + shadcn/ui (mirrors TRUSCA design system).",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:lib-gate": "node scripts/lib-test-gate.mjs",
    "test:ui": "playwright test --grep-invert \"@capture|@visual|@demo\"",
    "test:visual": "playwright test --grep @visual",
    "capture:ui": "playwright test --grep @capture",
    "demo:record": "playwright test --grep @demo",
    "token:lint": "node scripts/token-lint.mjs",
    "i18n:check": "node scripts/i18n-coverage.mjs"
  },
  "dependencies": {
    "@fontsource/inter": "5.3.0",
    "@fontsource/jetbrains-mono": "5.3.0",
    "@radix-ui/react-label": "2.1.13",
    "@radix-ui/react-progress": "1.1.14",
    "@radix-ui/react-slot": "1.3.1",
    "@radix-ui/react-tabs": "1.1.19",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cytoscape": "3.34.0",
    "cytoscape-dagre": "2.5.0",
    "i18next": "23.16.8",
    "i18next-browser-languagedetector": "8.2.1",
    "lucide-react": "0.577.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-i18next": "15.7.4",
    "tailwind-merge": "2.6.1",
    "tailwindcss-animate": "1.0.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "1.61.1",
    "@types/cytoscape-dagre": "2.3.3",
    "@types/node": "22.20.1",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "autoprefixer": "10.5.4",
    "postcss": "8.5.22",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "vite": "5.4.21",
    "vitest": "^2.1.9"
  }
}
